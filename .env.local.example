# ─── Movie Search App — Environment Variables ────────────────────────────────
# Copy this file to .env.local and fill in your own keys.
#   cp .env.local.example .env.local
# .env.local is gitignored — your keys will never be committed.
#
# NOTE: If keys are missing the app will still work using built-in mock data.

# ─── TMDB (The Movie Database) ────────────────────────────────────────────────
# Sign up & get your key: https://www.themoviedb.org/settings/api
# Used for: movie lists, search, pagination, images, credits, watch providers
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_READ_ACCESS_TOKEN=your_tmdb_read_access_token_here

# ─── OMDb (Open Movie Database) ───────────────────────────────────────────────
# Sign up & get your key: https://www.omdbapi.com/apikey.aspx
# IMPORTANT: You must click the activation link in the email they send you!
# Used for: IMDb / Rotten Tomatoes / Metacritic scores, awards, director, cast
OMDB_API_KEY=your_omdb_api_key_here
